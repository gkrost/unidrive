#!/usr/bin/env bash
# pre-push — run gitleaks against the current working tree before a push.
#
# Scope: the working tree only, not history. Pre-push is about what is
# about to leave this machine; a full-history scan lives in CI
# (scripts/ci/gitleaks.sh).
#
# If gitleaks is not installed, warn but do not block the push.
set -euo pipefail
cd "$(dirname "$0")/../.."

if ! command -v gitleaks >/dev/null 2>&1; then
    echo "pre-push: gitleaks not found on PATH; skipping secret scan." >&2
    echo "pre-push: install: https://github.com/gitleaks/gitleaks" >&2
    exit 0
fi

exec gitleaks detect \
    --source . \
    --config .gitleaks.toml \
    --redact \
    --verbose \
    --no-banner
